# PCR Manager Environment Variables
# Copier ce fichier en .env.local pour la configuration locale

# Mode développement / production
VITE_MODE=development

# API Tauri
TAURI_CONFIG_WINDOW_TITLE=PCR Manager

# Authentification
# VITE_WEBAUTHN_RP_ID=localhost

# Base de données
# Configurée dans Tauri (Rust)
# SQLite + SQLCipher

# ---------------------------------------------------------------------------
# Signature de code — GitHub Secrets (NE PAS mettre en .env.local)
# Ces valeurs doivent être configurées dans GitHub > Settings > Secrets
# ---------------------------------------------------------------------------

# Windows — Certificat OV/EV (PFX encodé en base64)
# WINDOWS_CERTIFICATE=<base64 du fichier .pfx>
# WINDOWS_CERTIFICATE_PASSWORD=<mot de passe du .pfx>
# Pour encoder : [Convert]::ToBase64String([IO.File]::ReadAllBytes("cert.pfx"))

# macOS — Apple Developer ID Application (P12 encodé en base64)
# APPLE_CERTIFICATE=<base64 du fichier .p12>
# APPLE_CERTIFICATE_PASSWORD=<mot de passe du .p12>
# APPLE_SIGNING_IDENTITY=Developer ID Application: Prénom Nom (TEAMID)
# KEYCHAIN_PASSWORD=<mot de passe temporaire pour le keychain CI>

# macOS — Notarisation Apple (Apple ID + mot de passe applicatif)
# APPLE_ID=votre@email.com
# APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx  (mot de passe applicatif, pas le vrai)
# APPLE_TEAM_ID=XXXXXXXXXX
