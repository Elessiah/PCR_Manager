# Auto-normalize line endings
* text=auto eol=lf

# Force LF for specific types
*.ts text eol=lf
*.tsx text eol=lf
*.rs text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files — don't touch
*.png binary
*.ico binary
*.exe binary
*.dll binary
